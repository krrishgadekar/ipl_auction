// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id                String            @id @default(uuid())
  name              String
  brandKey          String            @unique
  purseRemaining    Float             @default(800000000) // Default 80 Cr
  isOverseasCount   Int               @default(0)
  createdAt         DateTime          @default(now())
  teamPlayers       TeamPlayer[]
  powerCards        PowerCard[]
  top11Selection    Top11Selection?
}

model Player {
  id             String         @id @default(uuid())
  name           String
  category       Category       // BAT | BOWL | AR | WK
  grade          Grade          // A | B | C | D
  rating         Float
  nationality    Nationality    // IN | OS
  basePrice      Float
  isRiddle       Boolean        @default(false)
  auctionPlayers AuctionPlayer[]
  teamPlayers    TeamPlayer[]
}

model AuctionPlayer {
  id              String        @id @default(uuid())
  playerId        String
  player          Player        @relation(fields: [playerId], references: [id])
  status          AuctionStatus @default(UNSOLD) // UNSOLD | SOLD
  soldPrice       Float?
  soldToTeamId    String?
}

model TeamPlayer {
  id        String @id @default(uuid())
  teamId    String
  team      Team   @relation(fields: [teamId], references: [id])
  playerId  String
  player    Player @relation(fields: [playerId], references: [id])
  pricePaid Float
}

model AuctionState {
  id                 Int           @id @default(1)
  current_player_id  String?
  auction_status     AuctionStatus @default(NOT_STARTED) // NOT_STARTED | LIVE | SOLD | POST_AUCTION | LOCKED
}

model PowerCard {
  id      String        @id @default(uuid())
  teamId  String
  team    Team          @relation(fields: [teamId], references: [id])
  type    PowerCardType // GOD_EYE | MULLIGAN | FINAL_STRIKE | BID_FREEZER
  isUsed  Boolean       @default(false)
}

model Top11Selection {
  teamId        String   @id
  team          Team     @relation(fields: [teamId], references: [id])
  playerIds     String[] // Array of UUIDs
  captainId     String
  viceCaptainId String
}

enum Category {
  BAT
  BOWL
  AR
  WK
}

enum Grade {
  A
  B
  C
  D
}

enum Nationality {
  IN
  OS
}

enum AuctionStatus {
  NOT_STARTED
  LIVE
  SOLD
  UNSOLD
  POST_AUCTION
  LOCKED
}

enum PowerCardType {
  GOD_EYE
  MULLIGAN
  FINAL_STRIKE
  BID_FREEZER
}
