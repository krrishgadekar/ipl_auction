generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id                String          @id @default(uuid())
  name              String          @unique
  username          String          @unique
  password_hash     String
  active_session_id String?
  brand_key         String?         @unique
  franchise_name    String?
  brand_score       Decimal         @default(0)
  purse_remaining   Decimal         @default(120)
  squad_count       Int             @default(0)
  overseas_count    Int             @default(0)
  batsmen_count     Int             @default(0)
  bowlers_count     Int             @default(0)
  ar_count          Int             @default(0)
  wk_count          Int             @default(0)
  purchased_players Json            @default("[]")
  logo              String?
  primary_color     String?
  created_at        DateTime        @default(now())
  auction_players   AuctionPlayer[]
  power_cards       PowerCard[]
  team_players      TeamPlayer[]
  top11_selection   Top11Selection?
}

model Player {
  id                String         @id @default(uuid())
  rank              Int            @unique
  name              String
  team              String
  role              String
  category          Category
  pool              Pool
  grade             Grade
  rating            Int
  nationality       Nationality
  nationality_raw   String?
  base_price        Decimal
  legacy            Int            @default(0)
  url               String?
  image_url         String?
  is_riddle         Boolean        @default(false)
  matches           Int?
  bat_runs          Int?
  bat_sr            Decimal?
  bat_average       Decimal?
  bowl_wickets      Int?
  bowl_eco          Decimal?
  bowl_avg          Decimal?
  sub_experience    Int?
  sub_scoring       Int?
  sub_impact        Int?
  sub_consistency   Int?
  sub_wicket_taking Int?
  sub_economy       Int?
  sub_efficiency    Int?
  sub_batting       Int?
  sub_bowling       Int?
  sub_versatility   Int?
  auction_players   AuctionPlayer?
  team_players      TeamPlayer[]
}

model AuctionPlayer {
  id              String              @id @default(uuid())
  player_id       String              @unique
  status          PlayerAuctionStatus @default(UNSOLD)
  sold_price      Decimal?
  sold_to_team_id String?
  player          Player              @relation(fields: [player_id], references: [id])
  sold_to_team    Team?               @relation(fields: [sold_to_team_id], references: [id])
}

model TeamPlayer {
  id         String  @id @default(uuid())
  team_id    String
  player_id  String
  price_paid Decimal
  player     Player  @relation(fields: [player_id], references: [id])
  team       Team    @relation(fields: [team_id], references: [id])

  @@unique([team_id, player_id])
}

model AuctionState {
  id                     Int          @id @default(1)
  phase                  AuctionPhase @default(NOT_STARTED)
  current_player_id      String?
  current_item_id        String?
  current_bid            Decimal?
  highest_bidder_id      String?
  current_sequence_id    Int?
  current_sequence_index Int          @default(0)
  bid_frozen_team_id     String?
  auction_day            String       @default("Day 1")
  active_power_card      String?
  active_power_card_team String?
  gods_eye_revealed      Boolean      @default(false)
  bid_history            Json         @default("[]")
  last_sold_player_id    String?
  last_sold_price        Decimal?
  last_sold_team_id      String?
  last_sold_team_name    String?
}

model AuctionSequence {
  id             Int          @id
  name           String
  type           SequenceType @default(PLAYER)
  sequence_items Json         @default("[]")
}

model AdminUser {
  id                String  @id @default(uuid())
  username          String  @unique
  password_hash     String
  role              String
  active_session_id String?
}

model PowerCard {
  id      String        @id @default(uuid())
  team_id String
  type    PowerCardType
  is_used Boolean       @default(false)
  team    Team          @relation(fields: [team_id], references: [id])

  @@unique([team_id, type])
}

model Top11Selection {
  team_id         String   @id
  player_ids      String[]
  captain_id      String
  vice_captain_id String
  submitted_at    DateTime @default(now())
  team            Team     @relation(fields: [team_id], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  details    Json
  created_at DateTime @default(now())
}

model Franchise {
  id            Int     @id
  name          String  @unique
  short_name    String  @unique
  brand_score   Decimal @default(0)
  logo          String?
  primary_color String?
}

enum Category {
  BAT
  BOWL
  AR
  WK
}

enum Pool {
  BAT_WK
  BOWL
  AR
}

enum Grade {
  A
  B
  C
  D
}

enum Nationality {
  INDIAN
  OVERSEAS
}

enum AuctionPhase {
  NOT_STARTED
  FRANCHISE_PHASE
  POWER_CARD_PHASE
  LIVE
  POST_AUCTION
  COMPLETED
}

enum SequenceType {
  PLAYER
  FRANCHISE
  POWER_CARD
}

enum PlayerAuctionStatus {
  UNSOLD
  SOLD
}

enum PowerCardType {
  GOD_EYE
  MULLIGAN
  FINAL_STRIKE
  BID_FREEZER
  RIGHT_TO_MATCH
}
