// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id                String            @id @default(uuid())
  name              String
  brand_key         String            @unique
  purse_remaining   Float             @default(800000000) // Default 80 Cr
  is_overseas_count Int               @default(0)
  created_at        DateTime          @default(now())
  team_players      TeamPlayer[]
  power_cards       PowerCard[]
  top11_selection   Top11Selection?
}

model Player {
  id              String         @id @default(uuid())
  name            String
  category        Category       // BAT | BOWL | AR | WK
  grade           Grade          // A | B | C | D
  rating          Float
  nationality     Nationality    // IN | OS
  base_price      Float
  is_riddle       Boolean        @default(false)
  auction_players AuctionPlayer[]
  team_players    TeamPlayer[]
}

model AuctionPlayer {
  id              String        @id @default(uuid())
  player_id       String
  player          Player        @relation(fields: [player_id], references: [id])
  status          AuctionStatus @default(UNSOLD) // UNSOLD | SOLD
  sold_price      Float?
  sold_to_team_id String?
}

model TeamPlayer {
  id         String @id @default(uuid())
  team_id    String
  team       Team   @relation(fields: [team_id], references: [id])
  player_id  String
  player     Player @relation(fields: [player_id], references: [id])
  price_paid Float
}

model AuctionState {
  id                Int           @id @default(1)
  current_player_id String?
  auction_status    AuctionStatus @default(NOT_STARTED) // NOT_STARTED | LIVE | SOLD | POST_AUCTION | LOCKED
}

model PowerCard {
  id      String        @id @default(uuid())
  team_id String
  team    Team          @relation(fields: [team_id], references: [id])
  type    PowerCardType // GOD_EYE | MULLIGAN | FINAL_STRIKE | BID_FREEZER
  is_used Boolean       @default(false)
}

model Top11Selection {
  team_id         String   @id
  team            Team     @relation(fields: [team_id], references: [id])
  player_ids      String[] // Array of UUIDs
  captain_id      String
  vice_captain_id String
}

enum Category {
  BAT
  BOWL
  AR
  WK
}

enum Grade {
  A
  B
  C
  D
}

enum Nationality {
  IN
  OS
}

enum AuctionStatus {
  NOT_STARTED
  LIVE
  SOLD
  UNSOLD
  POST_AUCTION
  LOCKED
}

enum PowerCardType {
  GOD_EYE
  MULLIGAN
  FINAL_STRIKE
  BID_FREEZER
}
